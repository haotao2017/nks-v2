{
  "expo": {
    "name": "NKS Kontroll",
    "slug": "nks-kontroll",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "nkskontroll",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "no.nks.kontroll"
    },
    "android": {
      "package": "no.nks.kontroll"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Appen bruker bildene dine for å dokumentere kontroller.",
          "cameraPermission": "Appen bruker kameraet for å ta bilder av kontrollpunkter."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
