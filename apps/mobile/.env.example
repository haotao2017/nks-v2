# NKS 后端根地址(不含 /api,api-client 会自动加 /api 前缀)
# 注意:Expo 只暴露以 EXPO_PUBLIC_ 开头的环境变量给客户端代码。
# 模拟器/真机开发示例:
#   AWS:  EXPO_PUBLIC_API_BASE_URL=http://16.170.55.219:8080
#   本地: EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
#   真机连本机后端请用局域网 IP,不要用 localhost。
EXPO_PUBLIC_API_BASE_URL=http://16.170.55.219:8080
