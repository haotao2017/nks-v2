# ============================================================================
# NKS backend 环境变量样例 —— 复制为 .env 并填入真实值。
# 切勿把真实密钥/密码/token 提交到版本库。
# ============================================================================

# ---- Spring profile ----
# dev / prod
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ---- 数据库 (SQL Server / RDS) ----
# 旧库示例主机(仅作格式参考)：
#   jdbc:sqlserver://clone4dev.chu7ookb9pz4.eu-central-1.rds.amazonaws.com;databaseName=nbk-Db1;encrypt=true;trustServerCertificate=true
DB_URL=jdbc:sqlserver://<host>;databaseName=<db>;encrypt=true;trustServerCertificate=true
DB_USERNAME=
DB_PASSWORD=

# ---- JWT ----
# 必填。至少 32 个字符(256 bit)，否则应用启动失败(fail-fast)。
# 生成示例： openssl rand -base64 48
JWT_SECRET=
# token 有效期(毫秒)，默认 7 天 = 604800000
JWT_EXPIRATION_MS=604800000

# ---- 前端来源白名单 (CORS) ----
# 逗号分隔可配置多个来源，例如： https://app.example.com,https://admin.example.com
FRONTEND_URL=http://localhost:3000

# ---- AWS S3 ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_KEY=
AWS_REGION=eu-north-1
AWS_S3_BUCKET_NAME=
AWS_S3_URL_STATIC_PART=.s3.amazonaws.com/

# ---- 邮件 (SMTP) ----
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ---- Tripletex 集成 ----
TRIPLETEX_BASE_URL=https://tripletex.no
TRIPLETEX_CONSUMER_TOKEN=
TRIPLETEX_EMPLOYEE_TOKEN=
TRIPLETEX_COMPANY_ID=
